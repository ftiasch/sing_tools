global {
    tproxy_port: 12345
    tproxy_port_protect: true
    log_level: warn
    wan_interface: auto
    so_mark_from_dae: 0
    auto_config_kernel_parameter: true

    tcp_check_url: 'http://cp.cloudflare.com'
    tcp_check_http_method: HEAD
    check_interval: 30s
    check_tolerance: 50ms

    dial_mode: domain
    allow_insecure: false
    tls_implementation: utls
    utls_imitate: chrome_auto
}

node {
    bwh: 'vless://1870c1a3-cd84-4e91-aac6-551b143e8ed6@74.82.195.4:443?type=tcp&security=reality&flow=xtls-rprx-vision&fp=chrome&pbk=lt2OkFkaGBkQPKvnzfjVFZQOUrBwkkkvt_1GvQp58Qo&sni=www.apple.com'
}

group {
    proxy {
        policy: fixed(0)
    }
}

dns {
    ipversion_prefer: 4

    upstream {
        googledns: 'tcp+udp://dns.google:53'
        alidns: 'udp://dns.alidns.com:53'
    }

    routing {
        request {
            qname(suffix: push.apple.com, suffix: limao.tech, suffix: ftiasch.xyz) -> alidns
            qname(geosite:cn) -> alidns
            fallback: googledns
        }

        response {
            upstream(googledns) -> accept
            ip(geoip:private) && !qname(geosite:cn) -> googledns
            fallback: accept
        }
    }
}

routing {
    pname(NetworkManager) -> direct
    dip(224.0.0.0/3, 'ff00::/8') -> direct

    dip(100.0.0.0/8, 'fd7a:115c:a1e0::/48') -> block
    ipversion(6) -> block

    domain(geosite:category-ads-all) -> block

    pname(easytier-core, tailscaled) -> direct

    dip(geoip:private) -> direct

    domain(suffix: push.apple.com, suffix: codeforces.com) -> direct
    dip(17.0.0.0/8) -> direct
    l4proto(udp) && dport(3478, 41641) -> direct

    domain(geosite:cn) -> direct
    dip(geoip:cn) -> direct

    domain(geosite:apple@cn, geosite:category-game-platforms-download, geosite:category-games-cn, geosite:microsoft@cn, geosite:steam) -> direct

    domain(suffix: aur.archlinux.org) -> proxy

    fallback: proxy
}
